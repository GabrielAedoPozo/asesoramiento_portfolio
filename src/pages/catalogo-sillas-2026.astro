---
import Layout from '../layouts/Layout.astro';

const catalogPdf = '/Catalogo%20Sillas%202026%20Final%20pre.pdf';
---

<Layout title="Catálogo de Sillas 2026" description="Vista previa del catálogo y descarga en PDF.">
	<main class="relative isolate min-h-screen overflow-hidden bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.16),transparent_35%),linear-gradient(180deg,#f8fbff_0%,#eef5ff_52%,#ffffff_100%)] px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
		<div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
			<div class="absolute -top-24 left-1/2 h-80 w-80 -translate-x-1/2 rounded-full bg-blue-400/20 blur-3xl"></div>
			<div class="absolute bottom-0 right-0 h-96 w-96 rounded-full bg-cyan-300/20 blur-3xl"></div>
			<div class="absolute left-0 top-1/2 h-56 w-56 -translate-y-1/2 rounded-full bg-sky-300/10 blur-3xl"></div>
		</div>

		<section class="mx-auto w-full max-w-6xl">
			<div class="text-center">
				<span class="inline-flex items-center rounded-full border border-cyan-200 bg-white/80 px-4 py-2 text-xs font-semibold tracking-[0.22em] text-cyan-700 shadow-sm backdrop-blur">
					CATALOGO 2026
				</span>
				<h1 class="mt-5 text-3xl font-black text-slate-900 sm:text-5xl">
					Catálogo de Sillas 2026
				</h1>
				<p class="mx-auto mt-3 max-w-2xl text-sm text-slate-600 sm:text-base">
					Descubre una vista previa del PDF y descarga el catálogo completo en un solo clic.
				</p>
			</div>

			<div class="mt-9 overflow-hidden rounded-4xl border border-slate-200/70 bg-white/85 shadow-[0_20px_60px_rgba(15,23,42,0.10)] backdrop-blur-xl">
				<div class="flex items-center justify-between border-b border-slate-200/70 bg-linear-to-r from-blue-50 to-cyan-50 px-5 py-3 sm:px-7">
					<p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">Vista previa</p>
					<p class="text-xs text-slate-500">PDF</p>
				</div>
				<iframe
					title="Vista previa del Catálogo de Sillas 2026"
					src={`${catalogPdf}#page=1&zoom=page-width`}
					class="h-[62vh] w-full"
					loading="lazy"
				></iframe>
			</div>

			<div class="mt-8 flex flex-col items-center gap-4">
				<a
					href={catalogPdf}
					download="Catalogo_Sillas_2026"
					class="inline-flex items-center justify-center rounded-full bg-slate-900 px-7 py-3 text-sm font-semibold text-white transition duration-300 hover:-translate-y-0.5 hover:bg-blue-700 hover:shadow-lg"
				>
					Descargar catalogo
				</a>
				<p class="rounded-full border border-cyan-200 bg-white/80 px-5 py-2 text-center text-sm text-slate-700 backdrop-blur sm:text-base">
					Si quieres saber mas comunicate con +51 999 000 915
				</p>
			</div>
		</section>
	</main>
</Layout>